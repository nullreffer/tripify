generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String       @id @default(cuid())
  googleId       String       @unique
  email          String       @unique
  name           String
  avatar         String?
  isApproved     Boolean      @default(false)
  approvedAt     DateTime?
  trips          Trip[]
  tripMembers    TripMember[]
  invitesCreated Invite[]
  aiMessages     AiMessage[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Trip {
  id             String              @id @default(cuid())
  title          String
  description    String?
  coverImage     String?
  startDate      DateTime?
  endDate        DateTime?
  userId         String
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  members        TripMember[]
  invites        Invite[]
  stops          Stop[]
  itemCategories ItemCategory[]
  references     ExternalReference[]
  aiMessages     AiMessage[]
  days           TripDay[]
  reservations   Reservation[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

enum TripRole {
  PLANNER
  VIEWER
}

model TripMember {
  id        String   @id @default(cuid())
  tripId    String
  userId    String
  role      TripRole
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([tripId, userId])
}

model Invite {
  id          String    @id @default(cuid())
  token       String    @unique @default(cuid())
  tripId      String
  trip        Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  role        TripRole
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id], onDelete: Cascade)
  usedAt      DateTime?
  usedById    String?
  createdAt   DateTime  @default(now())
}

enum PinType {
  GENERAL
  STAY
  HOTEL
  CAMPGROUND
  HIKING_TRAIL
  RESTAURANT
  ATTRACTION
  GAS_STATION
  EV_CHARGER
  AIRPORT
  PARKING
  OTHER
}

model Stop {
  id         String    @id @default(cuid())
  tripId     String
  trip       Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  name       String
  address    String?
  lat        Float
  lng        Float
  order      Int
  pinType    PinType   @default(GENERAL)
  notes      String?
  targetDate DateTime?
  reached    Boolean   @default(false)
  reachedAt  DateTime?
  metadata   Json?
  dayEntries DayEntry[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model ItemCategory {
  id        String     @id @default(cuid())
  tripId    String
  trip      Trip       @relation(fields: [tripId], references: [id], onDelete: Cascade)
  name      String
  order     Int        @default(0)
  items     TripItem[]
  createdAt DateTime   @default(now())
}

model TripItem {
  id         String       @id @default(cuid())
  categoryId String
  category   ItemCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name       String
  done       Boolean      @default(false)
  color      String?
  order      Int          @default(0)
  quantity   Float?
  unit       String?
  notes      String?
  required   Boolean      @default(false)
  status     String       @default("have")
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model ExternalReference {
  id        String   @id @default(cuid())
  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  name      String
  url       String
  refType   String   @default("LINK")
  createdAt DateTime @default(now())
}

model AiMessage {
  id        String   @id @default(cuid())
  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String
  content   String
  createdAt DateTime @default(now())
}

// ── Days / Itinerary ──────────────────────────────────────────────────────────

enum ShowerStatus {
  YES
  NO
  UNKNOWN
}

enum EntryType {
  ACTIVITY
  TRAVEL
  ACCOMMODATION
  NOTE
}

model TripDay {
  id        String       @id @default(cuid())
  tripId    String
  trip      Trip         @relation(fields: [tripId], references: [id], onDelete: Cascade)
  date      DateTime?
  title     String?
  location  String?
  notes     String?
  shower    ShowerStatus @default(UNKNOWN)
  order     Int          @default(0)
  entries   DayEntry[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model DayEntry {
  id           String       @id @default(cuid())
  dayId        String
  day          TripDay      @relation(fields: [dayId], references: [id], onDelete: Cascade)
  type         EntryType
  title        String
  description  String?
  startTime    String?
  endTime      String?
  durationMins Int?
  order        Int          @default(0)
  fromLocation String?
  toLocation   String?
  stopId       String?
  stop         Stop?        @relation(fields: [stopId], references: [id], onDelete: SetNull)
  reservation  Reservation?
  metadata     Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Reservation {
  id                   String    @id @default(cuid())
  tripId               String
  trip                 Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  entryId              String?   @unique
  entry                DayEntry? @relation(fields: [entryId], references: [id], onDelete: SetNull)
  name                 String
  provider             String?
  confirmationNumber   String?
  referenceNumber      String?
  url                  String?
  phone                String?
  checkIn              DateTime?
  checkOut             DateTime?
  siteNumber           String?
  roomNumber           String?
  loop                 String?
  holder               String?
  cost                 String?
  cancellationDeadline DateTime?
  notes                String?
  isPrimary            Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}
