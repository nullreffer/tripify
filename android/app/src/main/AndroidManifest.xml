<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Car App Library surface permission for map drawing -->
    <uses-permission android:name="androidx.car.app.ACCESS_SURFACE" />

    <application
        android:name=".TripifyApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Tripify"
        android:usesCleartextTraffic="false"
        tools:targetApi="31">

        <!-- ── Phone UI ─────────────────────────────────────────────────────── -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".auth.LoginActivity"
            android:exported="true"
            android:launchMode="singleTop">
            <!-- Deep-link that Chrome Custom Tabs redirects back to after OAuth -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="tripify"
                    android:host="auth"
                    android:path="/callback" />
            </intent-filter>
        </activity>

        <!-- ── Android Auto / Car App Library ──────────────────────────────── -->
        <service
            android:name=".auto.TripifyCarAppService"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="androidx.car.app.CarAppService" />
                <!-- Declare as a navigation category app so NavigationTemplate is available -->
                <category android:name="androidx.car.app.category.NAVIGATION" />
            </intent-filter>

            <meta-data
                android:name="androidx.car.app.minCarApiLevel"
                android:value="1" />
        </service>

        <!-- Required for Android Auto host to find our automotive app descriptor -->
        <meta-data
            android:name="com.google.android.gms.car.application"
            android:resource="@xml/automotive_app_desc" />

    </application>

</manifest>
